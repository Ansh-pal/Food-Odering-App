    {
      "name": "02 Restaurants",
      "item": [
        {
          "name": "Member India - List Restaurants with Menu",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{memberIndiaToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/restaurants?includeMenu=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "restaurants"
              ],
              "query": [
                {
                  "key": "includeMenu",
                  "value": "true"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('All restaurants are India', function () {",
                  "  const countries = [...new Set(json.data.map((x) => x.country))];",
                  "  pm.expect(countries).to.eql(['India']);",
                  "});",
                  "if (json.data.length > 0 && json.data[0].menu.length > 0) {",
                  "  pm.environment.set('memberIndiaRestaurantId', json.data[0]._id);",
                  "  pm.environment.set('memberIndiaMenuItemId', json.data[0].menu[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
